# @actflow/reputation — example env. Copy to .env (never commit real secrets).
# All values are OPTIONAL: with none set, the service runs in FIXTURE mode.

# --- HTTP ---
REPUTATION_PORT=3402
REPUTATION_HOST=0.0.0.0
# CORS: "*" (default) reflects any origin; or comma-separated allow-list.
REPUTATION_CORS_ORIGIN=*

# --- Scoring (tunable, no secrets) ---
REPUTATION_RECENCY_HALFLIFE_DAYS=30
REPUTATION_SPARKLINE_BUCKETS=14
REPUTATION_CACHE_TTL_MS=60000

# --- LIVE BigQuery mode (set BOTH to switch from fixture to live) ---
# Path to a Google service-account JSON (Application Default Credentials).
# Queries bill to YOUR project; the Ethereum dataset itself is public.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
GCP_PROJECT_ID=your-billing-project-id
