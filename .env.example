# --- chain / rpc ---
SEPOLIA_RPC_URL=
MAINNET_RPC_URL=
ARC_TESTNET_RPC_URL=
LOCALHOST_RPC_URL=http://127.0.0.1:8545
# testnet-only deployer key; NEVER a funded mainnet key
DEPLOYER_PRIVATE_KEY=
ETHERSCAN_API_KEY=
# overrides bcConfig revenue token; falls back to mock deploy
REVENUE_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# --- apps/api (NestJS) ---
API_PORT=3401
MONGO_URI=mongodb://root:test@localhost:27018/actflow?authSource=admin
JWT_SECRET=
JWT_EXPIRATION=1d
NETWORK_RPC_URL=http://localhost:8545
CHAIN_ID=31337
ACT_MARKET_ADDRESS=0x0000000000000000000000000000000000000000
WALLET_ENCRYPTION_KEY=
CONTRACT_DEPLOYMENT_BLOCK=0
# OPTIONAL admin ops key; never a funded key
CONTRACT_OWNER_KEY=
# OPTIONAL ipfs pinning; stubs in-memory when unset
PINATA_JWT=
IPFS_GATEWAY=
CORS_ORIGINS=http://localhost:3400
REQUIRE_EMAIL_VERIFICATION=false

# --- apps/web (Next.js) ---
WEB_PORT=3400
NEXT_PUBLIC_API_URL=http://localhost:3401
NEXT_PUBLIC_RAINBOW_KIT_PROJECT_ID=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3400

# --- packages/mcp ---
API_BASE_URL=http://localhost:3401
ACT_USERNAME=
ACT_PASSWORD=

# --- packages/agents (Mastra) ---
ANTHROPIC_API_KEY=
ACTFLOW_AGENT_MODEL=
ACTFLOW_MCP_URL=
ACTFLOW_MCP_COMMAND=
ACTFLOW_MCP_ARGS=

# --- ens (phase 2) ---
# parent name that owns agents.<name>.eth subnames, e.g. actflow.eth
ENS_PARENT_NAME=
ENS_CHAIN=sepolia
NEXT_PUBLIC_ENS_PARENT_NAME=

# --- bigquery reputation (phase 3) ---
GOOGLE_APPLICATION_CREDENTIALS=.gcp-sa.json
GCP_PROJECT_ID=

# --- reputation service (phase 3) ---
REPUTATION_PORT=3402
NEXT_PUBLIC_REPUTATION_URL=http://localhost:3402

# --- privy agent wallets (phase 4) ---
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# --- uniswap trading api (phase 4) ---
UNISWAP_API_KEY=

# --- world id (phase 5) ---
WORLD_APP_ID=
WORLD_ACTION_ID=free-trial
# World ID v4.0 relying-party flow (server-side proof verification)
WORLD_RP_ID=
WORLD_SIGNER_KEY=
WORLD_API_KEY=

# --- unlink private payouts (phase 6) ---
# Route agent earnings (marketplace withdraw() proceeds) through @unlink-xyz/sdk:
# deposit -> private transfer to the owner -> optional withdraw. Unset = labeled
# MOCK mode (no funds/creds needed). Set BOTH UNLINK_API_KEY + UNLINK_MNEMONIC
# (and have @unlink-xyz/sdk installed) to enable real private transfers.
UNLINK_API_KEY=
UNLINK_MNEMONIC=
# Target chain id -> Unlink environment. Default 5042002 = Arc Testnet
# (arc-testnet). Also: 84532 base-sepolia, 11155111 ethereum-sepolia, 10143 monad-testnet.
UNLINK_CHAIN_ID=5042002
# ERC-20 token to shield. Default = Arc USDC (0x3600…0000) from @actflow/sdk.
UNLINK_TOKEN=
