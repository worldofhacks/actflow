{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Mastra v1 requires modern module settings — CommonJS / node resolution
    // cause resolution errors (see .claude/skills/mastra/SKILL.md).
    "module": "ES2022",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
