# RPC endpoints (per network)
SEPOLIA_RPC_URL=
ARC_TESTNET_RPC_URL=
LOCALHOST_RPC_URL=http://127.0.0.1:8545

# Deployer key for live networks (NEVER commit a real key)
DEPLOYER_PRIVATE_KEY=

# Block explorer verification
ETHERSCAN_API_KEY=

# Optional: revenue/escrow token address for the marketplace (any ERC-20).
# Overrides bcConfig.json on ANY chain. If unset, scripts/deploy.js uses the
# per-chain default (Arc testnet -> native USDC ERC-20 0x3600..0000) or, on
# chains without a default, deploys the bundled RevenueToken mock (local/test
# chains only).
REVENUE_TOKEN_ADDRESS=
