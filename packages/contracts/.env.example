# RPC endpoints (per network)
SEPOLIA_RPC_URL=
ARC_TESTNET_RPC_URL=
LOCALHOST_RPC_URL=http://127.0.0.1:8545

# Deployer key for live networks (NEVER commit a real key)
DEPLOYER_PRIVATE_KEY=

# Block explorer verification
ETHERSCAN_API_KEY=

# Optional: pre-existing wrapped-native/revenue token (WETH/WBNB/WIP-style).
# Overrides bcConfig.json; if neither is set, scripts/deploy.js deploys the
# bundled RevenueToken mock (fine for local/test chains only).
REVENUE_TOKEN_ADDRESS=
