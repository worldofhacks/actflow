# apps/api environment
# NOTE: the Joi schema in src/config/configuration.ts is wired into ConfigModule and runs
# at boot. The chain variables are REQUIRED even for DB-only work - the stub values below
# are enough to boot against docker-compose.dev.yml mongo + a local Hardhat node (8545).

# --- server ---
API_PORT=3401
NODE_ENV=local
# comma-separated allowlist; web app dev server
CORS_ORIGINS=http://localhost:3400

# --- database (docker compose -f docker-compose.dev.yml up -d) ---
MONGO_URI=mongodb://root:test@localhost:27018/actflow?authSource=admin

# --- auth ---
JWT_SECRET=change-me-dev-only
JWT_EXPIRATION=1d
# email module is not wired; leave false
REQUIRE_EMAIL_VERIFICATION=false

# --- chain (required by config validation; stub values are fine for DB-only work) ---
# local Hardhat node works: NETWORK_RPC_URL=http://localhost:8545, CHAIN_ID=31337
NETWORK_RPC_URL=http://localhost:8545
CHAIN_ID=31337
ACT_MARKET_ADDRESS=0x0000000000000000000000000000000000000000
REVENUE_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
# block the marketplace contract was deployed at (indexer backfill start)
CONTRACT_DEPLOYMENT_BLOCK=0

# --- custodial wallets (demo-only design; see SECURITY notes in the port) ---
WALLET_ENCRYPTION_KEY=change-me-dev-only

# --- admin ops (OPTIONAL - only for explicit contract-owner operations) ---
# never a funded mainnet key
CONTRACT_OWNER_KEY=

# --- ipfs (OPTIONAL - PinataIPFSClient runs as an in-memory stub when unset) ---
PINATA_JWT=
IPFS_GATEWAY=

# --- world id (OPTIONAL - proof-of-human free-trial gating; server-side verify) ---
# Verification is server-side only (NestJS apps/api). Prefer v4 (WORLD_RP_ID); when unset
# the service falls back to the v2 endpoint keyed by WORLD_APP_ID. All secrets are
# server-only - NEVER expose WORLD_API_KEY / WORLD_SIGNER_KEY to the client.
WORLD_APP_ID=          # IDKit widget app id (app_xxxxx); also v2 verify path segment
WORLD_RP_ID=           # v4 relying-party id (verify path segment); preferred when set
WORLD_ACTION_ID=free-trial
WORLD_API_KEY=         # server-only auth for the verify endpoint (Authorization: Bearer)
WORLD_SIGNER_KEY=      # server-only RP signing key (client signRequest, if v4 flow needs it)
# WORLD_API_HOST=https://developer.world.org   # override (e.g. staging) - optional
# WORLD_FREE_TRIALS=3                           # trials credited per new human - optional

# Public mirror for the frontend IDKit widget (Next.js web app):
# NEXT_PUBLIC_WORLD_APP_ID=<same as WORLD_APP_ID>
# NEXT_PUBLIC_WORLD_ACTION_ID=free-trial

# --- misc ---
LAST_DEPLOY=
