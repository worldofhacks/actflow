# API base URL (apps/api)
NEXT_PUBLIC_API_URL=http://localhost:3401

# --- Arc (payments) ---
# Block-explorer base for Arc testnet tx/address links shown on receipts. Config-
# driven; defaults to the SDK's documented ArcScan testnet base when unset. Only
# real (mock=false) settlements ever render an explorer link.
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app

# ERC-8004 reputation ranking API (services/reputation). Used by the Discovery /
# Leaderboard surface. Defaults to the documented local port (3402) when unset.
# The service returns source:"fixture" until GCP credentials are configured,
# then switches to live BigQuery automatically.
NEXT_PUBLIC_REPUTATION_URL=http://localhost:3402

# --- ERC-8004 identity (agent provisioning confirmation step) ---
# Optional block-explorer base used ONLY to render links for the provisioned
# ERC-8004 registry address / on-chain binding tx the API returns. The registry
# ADDRESS + chain id themselves come verbatim from POST /agents/provision (which
# resolves them from @actflow/agents' cited registry map) — never set here. Arc
# Testnet reuses NEXT_PUBLIC_ARC_EXPLORER_URL; this only matters for other chains.
NEXT_PUBLIC_ERC8004_EXPLORER_URL=

# WalletConnect Cloud project id (RainbowKit)
NEXT_PUBLIC_RAINBOW_KIT_PROJECT_ID=

# next-auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3400

# --- ENS (agent identity) ---
# Parent name that owns agent subnames, e.g. actflow.eth (client-readable).
NEXT_PUBLIC_ENS_PARENT_NAME=
# Mainnet RPC used for server-side ENS record resolution. Falls back to viem's
# public mainnet RPC when unset (rate-limited).
MAINNET_RPC_URL=

# --- World ID (free agent trials) ---
# IDKit widget app id (public), e.g. app_xxxxx. Mirrors the server WORLD_APP_ID.
NEXT_PUBLIC_WORLD_APP_ID=
# Action id the proof is bound to (public). Must match the server WORLD_ACTION_ID.
NEXT_PUBLIC_WORLD_ACTION_ID=free-trial
# IDKit environment: "staging" for the simulator (simulator.worldcoin.org), or
# "production" for the real World App. Defaults to production when unset.
NEXT_PUBLIC_WORLD_ENVIRONMENT=production
# Server-only secrets used by /api/world/rp-context to sign the proof request.
# These MUST NOT be NEXT_PUBLIC_ — they never reach the browser.
# WORLD_RP_ID    — the v4 Relying Party id (rp_xxxxx).
# WORLD_SIGNER_KEY — the RP signing key (hex) returned once by the Developer Portal.
# WORLD_ACTION_ID  — server source of truth for the action (defaults to free-trial).
WORLD_RP_ID=
WORLD_SIGNER_KEY=
WORLD_ACTION_ID=free-trial
