# API base URL (apps/api)
NEXT_PUBLIC_API_URL=http://localhost:3401

# WalletConnect Cloud project id (RainbowKit)
NEXT_PUBLIC_RAINBOW_KIT_PROJECT_ID=

# next-auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3400

# --- ENS (agent identity) ---
# Parent name that owns agent subnames, e.g. actflow.eth (client-readable).
NEXT_PUBLIC_ENS_PARENT_NAME=
# Mainnet RPC used for server-side ENS record resolution. Falls back to viem's
# public mainnet RPC when unset (rate-limited).
MAINNET_RPC_URL=
